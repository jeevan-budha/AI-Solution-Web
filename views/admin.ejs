    }

    function deleteEnquiry(id) {
      showConfirm('Delete this enquiry? This cannot be undone.', () => {
        DB.enquiries = DB.enquiries.filter(e => e.id !== id);
        renderEnquiries(); renderRecentEnquiries();
        showToast('Enquiry deleted', 'success');
      });
    }

    function exportCSV() {
      const headers = ['ID', 'Name', 'Email', 'Phone', 'Company', 'Country', 'Job Title', 'Details', 'Date'];
      const rows = DB.enquiries.map(e => [e.id, e.name, e.email, e.phone, e.company, e.country, e.jobTitle, e.jobDetails, e.date]);
      const csv = [headers, ...rows].map(r => r.join(',')).join('\n');
      const a = document.createElement('a');
      a.href = 'data:text/csv;charset=utf-8,' + encodeURIComponent(csv);
      a.download = 'enquiries.csv';
      a.click();
      showToast('CSV exported!', 'success');
    }

