        </button>
        <button onclick="deleteReview(${r.id})" class="w-7 h-7 rounded-lg flex items-center justify-center hover:bg-red-50 text-red-400 transition-all">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        </button>
      </div>
    </div>`).join('');
    }

    function reviewFormHTML(r = {}) {
      const stars = r.rating || 5;
      return `
    <div class="space-y-4">
      <div class="grid grid-cols-2 gap-4">
        <div><label>Customer Name</label><input type="text" id="rev-name" value="${r.name || ''}" /></div>
        <div><label>Company Name</label><input type="text" id="rev-company" value="${r.company || ''}" /></div>
      </div>
      <div>
        <label>Rating</label>
        <div class="star-rating flex gap-1 mt-1" id="star-container">
          ${[1, 2, 3, 4, 5].map(i => `<span class="${i <= stars ? 'filled' : ''}" onclick="setRating(${i})" data-val="${i}">★</span>`).join('')}
        </div>
        <input type="hidden" id="rev-rating" value="${stars}" />
      </div>
      <div><label>Review Text</label><textarea id="rev-text" rows="4" style="resize:none">${r.review || ''}</textarea></div>
      <div><label>Photo</label><div class="upload-zone p-4 text-center cursor-pointer"><p class="text-xs text-gray-400">Upload customer photo</p></div></div>
      <div><label>Status</label><select id="rev-status" style="width:100%"><option ${r.status === 'Active' ? 'selected' : ''}>Active</option><option ${r.status === 'Draft' ? 'selected' : ''}>Draft</option></select></div>
    </div>`;
    }

    function setRating(val) {
      document.getElementById('rev-rating').value = val;
      document.querySelectorAll('#star-container span').forEach((s, i) => { s.classList.toggle('filled', i < val); });
    }

    function openReviewModal() { openModal('Add Review', reviewFormHTML(), `<button onclick="closeModal()" class="btn-ghost px-5 py-2 rounded-xl text-sm font-semibold">Cancel</button><button onclick="saveReview(null)" class="btn-primary px-5 py-2 rounded-xl text-sm font-semibold">Add Review</button>`); }

    function editReview(id) {
      const r = DB.reviews.find(x => x.id === id);
      openModal('Edit Review', reviewFormHTML(r), `<button onclick="closeModal()" class="btn-ghost px-5 py-2 rounded-xl text-sm font-semibold">Cancel</button><button onclick="saveReview(${id})" class="btn-primary px-5 py-2 rounded-xl text-sm font-semibold">Save Changes</button>`);
    }

    function saveReview(id) {
      const name = document.getElementById('rev-name').value;
      if (!name) { showToast('Customer name required', 'error'); return; }
      if (id) {
        const r = DB.reviews.find(x => x.id === id);
        r.name = name; r.company = document.getElementById('rev-company').value;
        r.rating = parseInt(document.getElementById('rev-rating').value);
        r.review = document.getElementById('rev-text').value;
        r.status = document.getElementById('rev-status').value;
        showToast('Review updated!', 'success');
      } else {
        DB.reviews.push({ id: Date.now(), name, company: document.getElementById('rev-company').value, rating: parseInt(document.getElementById('rev-rating').value), review: document.getElementById('rev-text').value, status: document.getElementById('rev-status').value });
        showToast('Review added!', 'success');
      }
      closeModal(); renderReviews(); renderRecentReviews();
    }

    function deleteReview(id) {
      showConfirm('Delete this review?', () => { DB.reviews = DB.reviews.filter(r => r.id !== id); renderReviews(); renderRecentReviews(); showToast('Review deleted', 'success'); });
    }

    // =================== SETTINGS ===================
    function showSettingsTab(tab) {
      ['general', 'social', 'seo'].forEach(t => {
        document.getElementById('settings-' + t).classList.toggle('hidden', t !== tab);
        const btn = document.getElementById('tab-' + t);
        btn.classList.toggle('active', t === tab);
        btn.classList.toggle('text-gray-600', t !== tab);
        if (t === tab) { btn.style.background = 'var(--primary)'; btn.style.color = 'white'; }
        else { btn.style.background = ''; btn.style.color = ''; }
      });
    }
    // =================== PROFILE PICTURE ===================
    function initProfilePhoto() {
      const input = document.getElementById('profile-photo');
      input.addEventListener('change', function () {
        if (!input.files || !input.files[0]) return;
        const reader = new FileReader();
        reader.onload = function (e) {
          const dataUrl = e.target.result;
          // Replace the letter "A" avatar in the sidebar bottom
          const sidebarAvatar = document.querySelector('#sidebar .p-4 .w-9');
          sidebarAvatar.style.backgroundImage = `url(${dataUrl})`;
          sidebarAvatar.style.backgroundSize = 'cover';
          sidebarAvatar.style.backgroundPosition = 'center';
          sidebarAvatar.textContent = '';

          // Replace the profile card avatar
          const profileCard = document.querySelector('.avatar-ring');
          profileCard.style.backgroundImage = `url(${dataUrl})`;
          profileCard.style.backgroundSize = 'cover';
          profileCard.style.backgroundPosition = 'center';
          profileCard.textContent = '';

          // Replace top nav avatar button
          const topAvatar = document.querySelector('header button.rounded-xl[onclick="navigateTo(\'profile\')"]');
          topAvatar.style.backgroundImage = `url(${dataUrl})`;
          topAvatar.style.backgroundSize = 'cover';
          topAvatar.style.backgroundPosition = 'center';
          topAvatar.textContent = '';

          showToast('Profile picture updated!', 'success');
        };
        reader.readAsDataURL(input.files[0]);
      });
    }

    function saveProfile() {
      const firstName = document.querySelector('#sec-profile input[type="text"]').value.trim();
      const lastName = document.querySelectorAll('#sec-profile input[type="text"]')[1].value.trim();
      const email = document.querySelector('#sec-profile input[type="email"]').value.trim();
      const phone = document.querySelectorAll('#sec-profile input[type="text"]')[2].value.trim();

      if (!firstName || !email) { showToast('Name and email are required', 'error'); return; }

      const fullName = `${firstName} ${lastName}`.trim();

      // Update sidebar user info
      document.querySelector('#sidebar .user-info .text-white').textContent = fullName;
      document.querySelector('#sidebar .user-info .text-blue-300').textContent = email;

      // Update profile card name and email
      document.querySelector('#sec-profile h3.font-bold.text-gray-800.text-lg').textContent = fullName;
      document.querySelector('#sec-profile p.text-sm.text-gray-500').textContent = email;

      showToast('Profile updated successfully!', 'success');
    }


    // =================== LOGIN HISTORY ===================
    function renderLoginHistory() {
      const entries = [
        { date: '2025-06-07 09:15', ip: '192.168.1.100', browser: 'Chrome 124', status: 'Success' },
        { date: '2025-06-06 14:22', ip: '192.168.1.100', browser: 'Chrome 124', status: 'Success' },
        { date: '2025-06-05 08:45', ip: '10.0.0.1', browser: 'Firefox 125', status: 'Success' },
        { date: '2025-06-04 11:30', ip: '192.168.1.100', browser: 'Chrome 124', status: 'Failed' },
        { date: '2025-06-03 16:55', ip: '192.168.1.100', browser: 'Safari 17', status: 'Success' },
      ];
      const tb = document.getElementById('login-history-body');
      tb.innerHTML = entries.map(e => `
    <tr class="border-t border-gray-50">
      <td class="px-4 py-3 text-gray-600 text-xs">${e.date}</td>
      <td class="px-4 py-3 text-gray-500 text-xs">${e.ip}</td>
      <td class="px-4 py-3 text-gray-500 text-xs">${e.browser}</td>
      <td class="px-4 py-3"><span class="badge ${e.status === 'Success' ? 'badge-green' : 'badge-red'}">${e.status}</span></td>
    </tr>`).join('');
    }

    // Init settings tab style
    document.addEventListener('DOMContentLoaded', () => {
      document.getElementById('tab-general').style.background = 'var(--primary)';
      document.getElementById('tab-general').style.color = 'white';
    });
  </script>
</body>

</html>