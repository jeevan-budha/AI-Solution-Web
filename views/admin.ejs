    // =================== ENQUIRIES ===================
    function renderRecentEnquiries() {
      const tb = document.getElementById('recent-enquiries-body');
      tb.innerHTML = DB.enquiries.slice(0, 5).map(e => `
    <tr class="border-t border-gray-50">
      <td class="px-4 py-3 text-gray-700 font-medium">${e.name}</td>
      <td class="px-4 py-3"><span class="badge badge-blue">${e.country}</span></td>
      <td class="px-4 py-3 text-gray-400 text-xs">${e.date}</td>
    </tr>`).join('');
    }

    function renderEnquiries() {
      const search = (document.getElementById('enq-search') || { value: '' }).value.toLowerCase();
      const country = (document.getElementById('enq-country-filter') || { value: '' }).value;
      let filtered = DB.enquiries.filter(e => {
        const matchSearch = !search || e.name.toLowerCase().includes(search) || e.email.toLowerCase().includes(search) || e.company.toLowerCase().includes(search);
        const matchCountry = !country || e.country === country;
        return matchSearch && matchCountry;
      });
      document.getElementById('enq-total').textContent = filtered.length;
      const start = (currentEnqPage - 1) * enqPerPage;
      const paged = filtered.slice(start, start + enqPerPage);
      document.getElementById('enq-showing').textContent = paged.length;
      const tb = document.getElementById('enquiries-table-body');
      tb.innerHTML = paged.map(e => `
    <tr class="border-t border-gray-50">
      <td class="px-4 py-3 text-gray-400 text-xs">#${e.id}</td>
      <td class="px-4 py-3 font-medium text-gray-700">${e.name}</td>
      <td class="px-4 py-3 text-gray-500 text-xs hidden md:table-cell">${e.email}</td>
      <td class="px-4 py-3 hidden md:table-cell"><span class="badge badge-blue">${e.country}</span></td>
      <td class="px-4 py-3 text-gray-500 text-xs hidden lg:table-cell">${e.company}</td>
      <td class="px-4 py-3 text-gray-400 text-xs">${e.date}</td>
      <td class="px-4 py-3">
        <div class="flex gap-1">
          <button onclick="viewEnquiry(${e.id})" class="w-7 h-7 rounded-lg flex items-center justify-center hover:bg-blue-50 text-blue-400 transition-all" title="View">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
          </button>
          <button onclick="deleteEnquiry(${e.id})" class="w-7 h-7 rounded-lg flex items-center justify-center hover:bg-red-50 text-red-400 transition-all" title="Delete">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
          </button>
        </div>
      </td>
    </tr>`).join('');
      // Pagination
      const totalPages = Math.ceil(filtered.length / enqPerPage);
      const pg = document.getElementById('enq-pagination');
      pg.innerHTML = '';
      for (let i = 1; i <= totalPages; i++) {
        const btn = document.createElement('button');
        btn.textContent = i;
        btn.className = `w-8 h-8 rounded-lg text-sm font-semibold transition-all ${i === currentEnqPage ? 'btn-primary' : 'btn-ghost'}`;
        btn.onclick = () => { currentEnqPage = i; renderEnquiries(); };
        pg.appendChild(btn);
      }
    }

    function filterEnquiries() { currentEnqPage = 1; renderEnquiries(); }

    function viewEnquiry(id) {
      const e = DB.enquiries.find(x => x.id === id);
      if (!e) return;
      openModal('Enquiry Details', `
    <div class="grid grid-cols-2 gap-4 text-sm">
      <div><span class="text-gray-400 text-xs">Full Name</span><p class="font-semibold text-gray-800 mt-0.5">${e.name}</p></div>
      <div><span class="text-gray-400 text-xs">Email</span><p class="font-semibold text-gray-800 mt-0.5">${e.email}</p></div>
      <div><span class="text-gray-400 text-xs">Phone</span><p class="font-semibold text-gray-800 mt-0.5">${e.phone}</p></div>
      <div><span class="text-gray-400 text-xs">Country</span><p class="font-semibold text-gray-800 mt-0.5">${e.country}</p></div>
      <div><span class="text-gray-400 text-xs">Company</span><p class="font-semibold text-gray-800 mt-0.5">${e.company}</p></div>
      <div><span class="text-gray-400 text-xs">Job Title</span><p class="font-semibold text-gray-800 mt-0.5">${e.jobTitle}</p></div>
