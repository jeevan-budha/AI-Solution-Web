<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI-Solutions | Admin Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@latest/dist/umd/lucide.min.js"></script>
  <style>
    :root {
      --primary: #2E86DE;
      --secondary: #1B4F72;
      --accent: #89C2FF;
      --neutral: #D6DBDF;
      --bg: #F8FAFC;
    }

    * {
      font-family: 'Poppins', sans-serif;
      box-sizing: border-box;
    }

    body {
      background: var(--bg);
    }

    /* Sidebar */
    #sidebar {
      transition: transform 0.3s ease, width 0.3s ease;
    }

    #sidebar.collapsed {
      width: 72px !important;
    }

    #sidebar.collapsed .nav-label,
    #sidebar.collapsed .logo-text,
    #sidebar.collapsed .user-info {
      display: none !important;
    }

    #sidebar.collapsed .nav-item {
      justify-content: center;
    }

    #sidebar.collapsed .sidebar-logo {
      justify-content: center;
      padding: 0 16px;
    }

    #sidebar.collapsed .nav-section-label {
      display: none;
    }

    /* Scrollbar */
    ::-webkit-scrollbar {
      width: 5px;
      height: 5px;
    }

    ::-webkit-scrollbar-track {
      background: #f1f5f9;
    }

    ::-webkit-scrollbar-thumb {
      background: var(--accent);
      border-radius: 99px;
    }

    /* Active nav */
    .nav-item.active {
      background: var(--primary);
      color: white !important;
    }

    .nav-item.active svg {
      color: white !important;
    }

    .nav-item {
      transition: all 0.2s;
    }

    .nav-item:hover:not(.active) {
      background: rgba(46, 134, 222, 0.1);
      color: var(--primary);
    }

    /* Page sections */
    .page-section {
      display: none;
    }

    .page-section.active {
      display: block;
    }

    /* Card hover */
    .stat-card {
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .stat-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 30px rgba(46, 134, 222, 0.15);
    }

    /* Modal */
    .modal-backdrop {
      transition: opacity 0.2s;
    }

    .modal-box {
      transition: transform 0.25s, opacity 0.25s;
    }

    /* Toast */
    #toast-container {
      z-index: 9999;
    }

    .toast {
      animation: slideInRight 0.3s ease forwards;
    }

    .toast.hide {
      animation: slideOutRight 0.3s ease forwards;
    }

    @keyframes slideInRight {
      from {
        transform: translateX(120%);
        opacity: 0;
      }

      to {
        transform: translateX(0);
        opacity: 1;
      }
    }

    @keyframes slideOutRight {
      from {
        transform: translateX(0);
        opacity: 1;
      }

      to {
        transform: translateX(120%);
        opacity: 0;
      }
    }

    /* Table row hover */
    .data-table tbody tr:hover {
      background: rgba(46, 134, 222, 0.04);
    }

    /* Star rating */
    .star-rating span {
      cursor: pointer;
      font-size: 22px;
      color: #D6DBDF;
      transition: color 0.15s;
    }

    .star-rating span.filled {
      color: #F59E0B;
    }

    /* Login page */
    #login-page {
      background: linear-gradient(135deg, #1B4F72 0%, #2E86DE 60%, #89C2FF 100%);
    }

    /* Responsive table scroll */
    .table-wrap {
      overflow-x: auto;
    }

    /* Badge */
    .badge {
      display: inline-flex;
      align-items: center;
      padding: 2px 10px;
      border-radius: 99px;
      font-size: 11px;
      font-weight: 600;
    }

    .badge-green {
      background: #D1FAE5;
      color: #065F46;
    }

    .badge-yellow {
      background: #FEF3C7;
      color: #92400E;
    }

    .badge-red {
      background: #FEE2E2;
      color: #991B1B;
    }

    .badge-blue {
      background: #DBEAFE;
      color: #1E40AF;
    }

    .badge-gray {
      background: #F1F5F9;
      color: #475569;
    }

    /* Chart container */
    .chart-box {
      position: relative;
      height: 240px;
    }

    /* Image upload */
    .upload-zone {
      border: 2px dashed var(--neutral);
      border-radius: 12px;
      transition: border-color 0.2s;
    }

    .upload-zone:hover {
      border-color: var(--primary);
    }

    /* Profile avatar */
    .avatar-ring {
      box-shadow: 0 0 0 4px white, 0 0 0 6px var(--primary);
    }

    /* Sidebar overlay for mobile */
    #sidebar-overlay {
      display: none;
    }

    @media (max-width: 768px) {
      #sidebar {
        position: fixed;
        left: 0;
        top: 0;
        height: 100vh;
        z-index: 200;
        transform: translateX(-100%);
      }

      #sidebar.mobile-open {
        transform: translateX(0);
      }

      #sidebar-overlay {
        display: block;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.4);
        z-index: 199;
      }
    }

    input[type="file"] {
      display: none;
    }

    .btn-primary {
      background: var(--primary);
      color: white;
    }

    .btn-primary:hover {
      background: #2270c0;
    }

    .btn-secondary {
      background: var(--secondary);
      color: white;
    }

    .btn-danger {
      background: #EF4444;
      color: white;
    }

    .btn-danger:hover {
      background: #DC2626;
    }

    .btn-ghost {
      background: #F1F5F9;
      color: #475569;
    }

    .btn-ghost:hover {
      background: #E2E8F0;
    }

    select,
    input:not([type="checkbox"]):not([type="file"]):not([type="date"]):not([type="time"]):not([type="radio"]),
    textarea {
      outline: none;
      border: 1.5px solid var(--neutral);
      border-radius: 10px;
      padding: 10px 14px;
      font-family: 'Poppins', sans-serif;
      font-size: 13px;
      width: 100%;
      transition: border-color 0.2s, box-shadow 0.2s;
      background: #fff;
      color: #1f2937;
      line-height: 1.5;
    }

    select:focus,
    input:not([type="checkbox"]):not([type="file"]):not([type="date"]):not([type="time"]):not([type="radio"]):focus,
    textarea:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(46, 134, 222, 0.12);
    }


    label {
      font-size: 12px;
      font-weight: 600;
      color: #374151;
      display: block;
      margin-bottom: 4px;
    }

    .input-password-wrap {
      position: relative;
    }

    .input-password-wrap input {
      padding-right: 42px;
    }

    .input-password-wrap button {
      position: absolute;
      right: 10px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      padding: 0;
      width: auto;
      cursor: pointer;
      color: #9ca3af;
      display: flex;
      align-items: center;
    }

    .input-password-wrap button:hover {
      color: #4b5563;
    }

    /* Top nav search — override width & border reset */
    header input[type="text"] {
      border: none !important;
      box-shadow: none !important;
      padding: 0 !important;
      border-radius: 0 !important;
      background: transparent !important;
      width: 100% !important;
    }

    label {
      font-size: 12px;
      font-weight: 600;
      color: #374151;
      display: block;
      margin-bottom: 5px;
    }

    textarea {
      padding: 10px 14px;
      line-height: 1.7;
      resize: vertical;
      min-height: 80px;
    }

    select,
    input,
    textarea {
      outline: none;
      border: 1.5px solid var(--neutral);
      border-radius: 10px;
      padding: 10px 14px;
      font-family: 'Poppins', sans-serif;
      font-size: 13px;
      width: 100%;
      transition: border-color 0.2s, box-shadow 0.2s;
      background: #fff;
      color: #1f2937;
      line-height: 1.6;
      box-sizing: border-box;
    }

    select:focus,
    input:focus,
    textarea:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(46, 134, 222, 0.12);
    }

    textarea {
      padding: 12px 14px !important;
      line-height: 1.7 !important;
      resize: vertical;
      min-height: 90px;
      display: block;
    }
  </style>
</head>

<body>

  <!-- LOGIN PAGE  -->
  <div id="login-page" class="fixed inset-0 flex items-center justify-center z-50">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden">
      <!-- Header -->
      <div style="background:linear-gradient(135deg,#1B4F72,#2E86DE)" class="p-8 text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-white/20 mb-4">
          <img src="/Img/ai_solutions_logo.jpg" alt="">
        </div>
        <h1 class="text-2xl font-bold text-white">AI-Solutions</h1>
        <p class="text-blue-200 text-sm mt-1">Admin Control Panel</p>
      </div>
      <!-- Form -->
      <div class="p-8">
        <div class="mb-5">
          <label>Email Address</label>
          <input id="login-email" type="email" placeholder="Enter your email address" />
        </div>
        <div class="mb-5">
          <label>Password</label>
          <div class="input-password-wrap">
            <input id="login-password" type="password" placeholder="Enter your password" />
            <button onclick="toggleLoginPass()" type="button">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            </button>
          </div>
        </div>
        <div class="flex items-center justify-between mb-6">
          <label class="flex items-center gap-2 cursor-pointer" style="margin-bottom:0">
            <input type="checkbox" class="w-4 h-4 accent-blue-600" checked /> <span
              class="text-sm text-gray-600">Remember me</span>
          </label>
          <button onclick="showToast('Password reset link sent!','info')" class="text-sm font-medium"
            style="color:var(--primary)">Forgot Password?</button>
        </div>
        <button onclick="doLogin()"
          class="w-full btn-primary py-3 rounded-xl font-semibold text-sm transition-all hover:shadow-lg hover:shadow-blue-200">Sign
          In to Dashboard</button>
        <p class="text-center text-xs text-gray-400 mt-5">© 2025 AI-Solutions. All rights reserved.</p>
      </div>
    </div>
  </div>

 <!-- TOAST -->
  <div id="toast-container" class="fixed top-5 right-5 flex flex-col gap-3 pointer-events-none"></div>
  <div id="confirm-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center">
    <div class="modal-backdrop absolute inset-0 bg-black/40" onclick="closeConfirm()"></div>
    <div class="modal-box relative bg-white rounded-2xl shadow-2xl p-7 w-full max-w-sm mx-4 text-center">
      <div class="w-14 h-14 rounded-full bg-red-100 flex items-center justify-center mx-auto mb-4">
        <svg class="w-7 h-7 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
        </svg>
      </div>
      <h3 class="text-lg font-bold text-gray-800 mb-2">Confirm Delete</h3>
      <p class="text-sm text-gray-500 mb-6" id="confirm-text">Are you sure you want to delete this item? This action
        cannot be undone.</p>
      <div class="flex gap-3">
        <button onclick="closeConfirm()"
          class="flex-1 btn-ghost py-2 rounded-lg text-sm font-semibold transition-all">Cancel</button>
        <button onclick="executeConfirm()"
          class="flex-1 btn-danger py-2 rounded-lg text-sm font-semibold transition-all">Delete</button>
      </div>
    </div>
  </div>

  <div id="generic-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center">
    <div class="modal-backdrop absolute inset-0 bg-black/40" onclick="closeModal()"></div>
    <div class="modal-box relative bg-white rounded-2xl shadow-2xl w-full max-w-2xl mx-4 max-h-[90vh] flex flex-col">
      <div class="flex items-center justify-between p-6 border-b border-gray-100">
        <h3 class="text-lg font-bold text-gray-800" id="modal-title">Modal Title</h3>
        <button onclick="closeModal()"
          class="w-9 h-9 flex items-center justify-center rounded-full bg-gray-100 hover:bg-gray-200 transition-all">
          <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div class="overflow-y-auto p-6 flex-1" id="modal-body"></div>
      <div class="p-6 border-t border-gray-100 flex gap-3 justify-end" id="modal-footer"></div>
    </div>
  </div>

  <div id="sidebar-overlay" onclick="closeMobileSidebar()"></div>

  <div id="app-shell" class="hidden flex h-screen overflow-hidden">

    <aside id="sidebar" class="w-64 flex-shrink-0 flex flex-col overflow-hidden" style="background:var(--secondary)">
      <!-- Logo -->
      <div class="sidebar-logo flex items-center gap-3 p-5 border-b border-white/10 h-16">
        <div class="w-9 h-9 rounded-xl flex-shrink-0 flex items-center justify-center"
          style="background:var(--primary)">
          <img src="/Img/ai_solutions_logo.jpg" alt="">
        </div>
        <div class="logo-text">
          <div class="text-white font-bold text-sm leading-tight">AI-Solutions</div>
          <div class="text-blue-300 text-xs">Admin Panel</div>
        </div>
      </div>

      <!-- Nav -->
      <nav class="flex-1 overflow-y-auto py-4 px-3 space-y-0.5">
        <div class="nav-section-label text-xs font-semibold text-blue-300 px-3 py-2 uppercase tracking-wider">Main</div>
        <a class="nav-item active flex items-center gap-3 px-3 py-2.5 rounded-xl cursor-pointer text-white text-sm font-medium"
