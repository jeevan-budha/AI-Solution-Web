<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI Solutions – Transform Your Business with AI</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
    integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw=="
    crossorigin="anonymous" referrerpolicy="no-referrer" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#2E86DE',
            secondary: '#1B4F72',
            accent: '#89C2FF',
            lgray: '#D6DBDF',
            bg: '#F8FAFC',
          },
          fontFamily: { poppins: ['Poppins', 'sans-serif'] },
        }
      }
    }
  </script>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0
    }

    body {
      font-family: 'Poppins', sans-serif;
      background: #F8FAFC;
      color: #1a2a3a;
      overflow-x: hidden
    }

    :root {
      --primary: #2E86DE;
      --secondary: #1B4F72;
      --accent: #89C2FF;
      --lgray: #D6DBDF;
      --bg: #F8FAFC
    }

    /* ── Scrollbar ── */
    ::-webkit-scrollbar {
      width: 6px
    }

    ::-webkit-scrollbar-track {
      background: #f1f5f9
    }

    ::-webkit-scrollbar-thumb {
      background: var(--primary);
      border-radius: 4px
    }

    /* ── Page visibility ── */
    .page {
      display: none
    }

    .page.active {
      display: block
    }

    /* ── Nav ── */
    #navbar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      transition: all .3s
    }

    #navbar.scrolled {
      background: rgba(255, 255, 255, .96);
      backdrop-filter: blur(12px);
      box-shadow: 0 2px 20px rgba(46, 134, 222, .12)
    }

    .nav-link {
      position: relative;
      cursor: pointer;
      padding: 6px 2px;
      font-size: .875rem;
      font-weight: 500;
      color: #334155;
      transition: color .2s
    }

    .nav-link::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 0;
      height: 2px;
      background: var(--primary);
      transition: width .3s
    }

    .nav-link:hover,
    .nav-link.active {
      color: var(--primary)
    }

    .nav-link:hover::after,
    .nav-link.active::after {
      width: 100%
    }

    /* ── Hero ── */
    .hero-bg {
      background: linear-gradient(135deg, #0a1628 0%, #1B4F72 50%, #2E86DE 100%);
      position: relative;
      overflow: hidden;
      /* background-image: url('https://lottie.host/bc429d4d-6d12-4f32-9093-ae55bd8a259f/6mfVLzAzrw.lottie');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-attachment: fixed; */
    }

    .hero-bg::before {
      content: '';
      position: absolute;
      inset: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%2389C2FF' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E")
    }

    .floating-blob {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: .18;
      animation: blobFloat 8s ease-in-out infinite
    }

    @keyframes blobFloat {

      0%,
      100% {
        transform: translate(0, 0) scale(1)
      }

      50% {
        transform: translate(30px, -20px) scale(1.05)
      }
    }

    /* ── Cards ── */
    .card {
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 4px 20px rgba(46, 134, 222, .08);
      transition: transform .3s, box-shadow .3s
    }

    .card:hover {
      transform: translateY(-6px);
      box-shadow: 0 12px 40px rgba(46, 134, 222, .18)
    }

    .stat-card {
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      color: #fff;
      border-radius: 16px;
      padding: 2rem;
      text-align: center
    }

    /* ── Sections ── */
    .section-tag {
      display: inline-block;
      background: rgba(46, 134, 222, .1);
      color: var(--primary);
      font-size: .75rem;
      font-weight: 600;
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: 6px 16px;
      border-radius: 50px;
      margin-bottom: 1rem
    }

    .gradient-text {
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text
    }

    /* ── Buttons ── */
    .btn-primary {
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      color: #fff;
      padding: .75rem 2rem;
      border-radius: 50px;
      font-weight: 600;
      font-size: .9rem;
      border: none;
      cursor: pointer;
      transition: all .3s;
      box-shadow: 0 4px 15px rgba(46, 134, 222, .3)
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(46, 134, 222, .45)
    }

    .btn-outline {
      background: transparent;
      color: var(--primary);
      padding: .1rem 2rem;
      border-radius: 50px;
      font-weight: 600;
      font-size: .9rem;
      border: 2px solid var(--primary);
      cursor: pointer;
      transition: all .3s
    }

    .btn-outline:hover {
      background: var(--primary);
      color: #fff;
      transform: translateY(-2px)
    }

    /* ── Rating stars ── */
    .stars span {
      color: #f59e0b;
      font-size: 1.1rem
    }

    /* ── Timeline ── */
    .timeline-line {
      position: absolute;
      left: 50%;
      top: 0;
      bottom: 0;
      width: 2px;
      background: linear-gradient(to bottom, var(--primary), var(--secondary));
      transform: translateX(-50%)
    }

    @media(max-width:768px) {
      .timeline-line {
        left: 20px
      }
    }

    /* ── Lightbox ── */
    #lightbox {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, .9);
      z-index: 999;
      align-items: center;
      justify-content: center
    }

    #lightbox.open {
      display: flex
    }

    #lightbox img {
      max-width: 90vw;
      max-height: 90vh;
      border-radius: 12px;
      box-shadow: 0 0 60px rgba(0, 0, 0, .5)
    }

    /* ── Chat ── */
    #chat-box {
      height: 380px;
      overflow-y: auto;
      padding: 1rem;
      display: flex;
      flex-direction: column;
      gap: .75rem
    }

    .chat-msg {
      max-width: 75%;
      padding: .75rem 1rem;
      border-radius: 18px;
      font-size: .85rem;
      line-height: 1.5;
      animation: msgIn .25s ease
    }

    @keyframes msgIn {
      from {
        opacity: 0;
        transform: translateY(8px)
      }

      to {
        opacity: 1;
        transform: translateY(0)
      }
    }

    .chat-msg.bot {
      background: linear-gradient(135deg, #e8f4fd, #dbeeff);
      color: #1a2a3a;
      border-bottom-left-radius: 4px;
      align-self: flex-start
    }

    .chat-msg.user {
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      color: #fff;
      border-bottom-right-radius: 4px;
      align-self: flex-end
    }

    .typing-dot {
      width: 8px;
      height: 8px;
      background: var(--primary);
      border-radius: 50%;
      display: inline-block;
      animation: typing 1s infinite
    }

    .typing-dot:nth-child(2) {
      animation-delay: .2s
    }

    .typing-dot:nth-child(3) {
      animation-delay: .4s
    }

    @keyframes typing {

      0%,
      80%,
      100% {
        transform: scale(1);
        opacity: .6
      }

      40% {
        transform: scale(1.3);
        opacity: 1
      }
    }

    /* ── Progress bar ── */
    .progress-bar {
      height: 8px;
      background: #e2e8f0;
      border-radius: 50px;
      overflow: hidden
    }

    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--primary), var(--accent));
      border-radius: 50px;
      transition: width 1.5s ease
    }

    /* ── Fade-in scroll ── */
    .fade-up {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity .7s ease, transform .7s ease
    }

    .fade-up.visible {
      opacity: 1;
      transform: translateY(0)
    }

    /* ── Mobile Menu ── */
    #mobile-menu {
      display: none
    }

    #mobile-menu.open {
      display: block
    }

    /* ── Form ── */
    .form-input {
      width: 100%;
      padding: .75rem 1rem;
      border: 1.5px solid #e2e8f0;
      border-radius: 10px;
      font-family: 'Poppins', sans-serif;
      font-size: .875rem;
      outline: none;
      transition: border-color .2s, box-shadow .2s;
      background: #fff
    }

    .form-input:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(46, 134, 222, .12)
    }

    .form-input.error {
      border-color: #ef4444
    }

    .error-msg {
      color: #ef4444;
      font-size: .75rem;
      margin-top: .25rem;
      display: none
    }

    .error-msg.show {
      display: block
    }

    /* Footer */
    footer a {
      color: #94a3b8;
      font-size: .85rem;
      transition: color .2s
    }

    footer a:hover {
      color: var(--accent)
    }

    html {
      scroll-behavior: smooth;
    }

    /* ── page tab active ── */
    .ptab {
      position: relative;
      padding: 14px 28px;
      font-size: .875rem;
      font-weight: 600;
      color: #64748b;
      border-bottom: 3px solid transparent;
      cursor: pointer;
      transition: color .2s, border-color .2s;
      background: none;
      border-top: none;
      border-left: none;
      border-right: none;
      outline: none;
    }

    .ptab.active {
      color: #2E86DE;
      border-bottom-color: #2E86DE;
    }

    /* ── filter pill ── */
    .fpill {
      padding: 8px 20px;
      border-radius: 999px;
      border: 1.5px solid #D6DBDF;
      font-size: .8rem;
      font-weight: 500;
      color: #64748b;
      background: #fff;
      cursor: pointer;
      transition: all .22s;
      white-space: nowrap;
    }

    .fpill:hover {
      border-color: #2E86DE;
      color: #2E86DE;
    }

    .fpill.active {
      background: #2E86DE;
      border-color: #2E86DE;
      color: #fff;
      box-shadow: 0 4px 14px rgba(46, 134, 222, .35);
    }

    /* ── gallery card ── */
    .gcard {
      background: #fff;
      border-radius: 18px;
      overflow: hidden;
      border: 1px solid #e8edf2;
      transition: transform .3s, box-shadow .3s;
    }

    .gcard:hover {
      transform: translateY(-7px);
      box-shadow: 0 22px 45px rgba(46, 134, 222, .16);
    }

    .gcard .gimg {
      overflow: hidden;
      height: 210px;
      position: relative;
    }

    .gcard .gimg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform .45s ease;
    }

    .gcard:hover .gimg img {
      transform: scale(1.09);
    }

    .gcard .goverlay {
      position: absolute;
      inset: 0;
      background: rgba(27, 79, 114, .72);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity .3s;
    }

    .gcard:hover .goverlay {
      opacity: 1;
    }

    /* ── blog card ── */
    .bcard {
      background: #fff;
      border-radius: 18px;
      overflow: hidden;
      border: 1px solid #e8edf2;
      transition: transform .3s, box-shadow .3s;
      display: flex;
      flex-direction: column;
    }

    .bcard:hover {
      transform: translateY(-7px);
      box-shadow: 0 22px 45px rgba(46, 134, 222, .14);
    }

    .bcard .bimg {
      overflow: hidden;
      height: 200px;
    }

    .bcard .bimg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform .45s ease;
    }

    .bcard:hover .bimg img {
      transform: scale(1.07);
    }

    /* ── hero ── */
    .hero-overlay {
      background: linear-gradient(135deg, rgba(27, 79, 114, .9) 0%, rgba(46, 134, 222, .75) 100%);
    }

    .grad-text {
      background: linear-gradient(135deg, #2E86DE, #89C2FF);
      background-clip: text;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    /* ── scroll reveal ── */
    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity .55s ease, transform .55s ease;
    }

    .reveal.show {
      opacity: 1;
      transform: none;
    }

    /* ── lightbox ── */
    #lb {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 9999;
      background: rgba(0, 0, 0, .88);
      backdrop-filter: blur(6px);
      align-items: center;
      justify-content: center;
      padding: 16px;
    }

    #lb.open {
      display: flex;
    }

    #lbPanel {
      animation: lbPop .32s ease;
      background: #fff;
      border-radius: 20px;
      overflow: hidden;
      max-width: 880px;
      width: 100%;
      max-height: 90vh;
      display: flex;
      flex-direction: column;
      position: relative;
    }

    @media(min-width:640px) {
      #lbPanel {
        flex-direction: row;
      }
    }

    @keyframes lbPop {
      from {
        opacity: 0;
        transform: scale(.9);
      }

      to {
        opacity: 1;
        transform: scale(1);
      }
    }

    #lbImg {
      width: 100%;
      height: 240px;
      object-fit: cover;
    }

    @media(min-width:640px) {
      #lbImg {
        width: 55%;
        height: auto;
        max-height: 90vh;
      }
    }

    #lbInfo {
      padding: 28px;
      overflow-y: auto;
      flex: 1;
    }

    /* ── blog modal ── */
    #bm {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 9999;
      background: rgba(0, 0, 0, .65);
      backdrop-filter: blur(5px);
      align-items: center;
      justify-content: center;
      padding: 16px;
    }

    #bm.open {
      display: flex;
    }

    #bmPanel {
      animation: lbPop .3s ease;
      background: #fff;
      border-radius: 20px;
      max-width: 760px;
      width: 100%;
      max-height: 92vh;
      overflow-y: auto;
    }

    #bmPanel::-webkit-scrollbar {
      width: 5px;
    }

    #bmPanel::-webkit-scrollbar-thumb {
      background: #D6DBDF;
      border-radius: 4px;
    }

    /* ── featured blog ── */
    .feat-blog {
      background: #fff;
      border-radius: 24px;
      overflow: hidden;
      border: 1px solid #e8edf2;
      display: flex;
      flex-direction: column;
    }

    @media(min-width:1024px) {
      .feat-blog {
        flex-direction: row;
      }
    }

    /* ── counter ── */
    .cnum {
      font-variant-numeric: tabular-nums;
    }

    /* ── newsletter ── */
    .nl-input {
      background: rgba(255, 255, 255, .1);
      border: 1.5px solid rgba(255, 255, 255, .25);
      color: #fff;
      border-radius: 12px;
      padding: 13px 18px;
      font-size: .875rem;
      width: 100%;
      outline: none;
      transition: border-color .2s;
    }

    .nl-input::placeholder {
      color: rgba(255, 255, 255, .5);
    }

    .nl-input:focus {
      border-color: #89C2FF;
    }

    /* ── badge ── */
    .badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .04em;
      text-transform: uppercase;
    }

    .badge-primary {
      background: rgba(46, 134, 222, .12);
      color: #2E86DE;
    }

    .badge-white {
      background: rgba(255, 255, 255, .9);
      color: #1B4F72;
    }

    /* ── tags ── */
    .tag-workshop {
      background: #EFF6FF;
      color: #2563EB;
    }

    .tag-conference {
      background: #F0FDF4;
      color: #16A34A;
    }

    .tag-demo {
      background: #FFF7ED;
      color: #EA580C;
    }

    .tag-team {
      background: #FAF5FF;
      color: #9333EA;
    }

    .tag-client {
      background: #FFF1F2;
      color: #E11D48;
    }

    .tag-success {
      background: #ECFDF5;
      color: #059669;
    }

    /* empty state */
    .empty-state {
      padding: 64px 20px;
      text-align: center;
      color: #94a3b8;
    }

    /* read more btn */
    .btn-outline {
      border: 1.5px solid #2E86DE;
      color: #2E86DE;
      background: transparent;
      border-radius: 10px;
      padding: 10px 20px;
      font-size: .8rem;
      font-weight: 600;
      cursor: pointer;
      transition: all .2s;
    }

    .btn-outline:hover {
      background: #2E86DE;
      color: #fff;
    }

    .btn-primary {
      background: #2E86DE;
      color: #fff;
      border: none;
      border-radius: 10px;
      padding: 11px 24px;
      font-size: .875rem;
      font-weight: 600;
      cursor: pointer;
      transition: background .2s, box-shadow .2s;
    }

    .btn-primary:hover {
      background: #1B4F72;
      box-shadow: 0 8px 24px rgba(46, 134, 222, .35);
    }
  </style>
  <style>
    /* ============================================================
   events.css — AI Solutions Events Page
   ============================================================ */


