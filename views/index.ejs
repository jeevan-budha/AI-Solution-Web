      background-size: 60px 60px;
    }

    .orb-1 {
      background: radial-gradient(circle, #2E86DE, transparent);
    }

    .orb-2 {
      background: radial-gradient(circle, #89C2FF, transparent);
    }

    .orb-3 {
      background: radial-gradient(circle, #1B4F72, transparent);
    }

    .text-gradient-blue {
