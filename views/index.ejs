    // ── State ────────────────────────────────────────────────────
    let chatHistory = [];
    let chatOpen = false;
    let chatMinimized = false;
    let msgCount = 0;

    // ── Helpers ──────────────────────────────────────────────────
    function pad2(n) { return String(n).padStart(2, '0'); }

    function nowTime() {
      const d = new Date();
      return `${pad2(d.getHours())}:${pad2(d.getMinutes())}`;
    }

    function escHtml(s) {
      return s.replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' }[c]));
    }

    function mdToHtml(text) {
      return text
        .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.*?)\*/g, '<em>$1</em>')
        .replace(/`(.*?)`/g, '<code style="background:rgba(46,134,222,.12);padding:1px 5px;border-radius:4px;font-size:12px;">$1</code>')
        .replace(/\n/g, '<br>');
    }

    function scrollBottom() {
      const body = document.getElementById('chatBody');
      if (body) setTimeout(() => { body.scrollTop = body.scrollHeight; }, 40);
    }

    // ── DOM helpers ──────────────────────────────────────────────
    function appendUserBubble(text) {
      const body = document.getElementById('chatBody');
      if (!body) return;
      const el = document.createElement('div');
      el.className = 'msg-row user';
      el.innerHTML = `
    <div class="msg-avatar user-av">👤</div>
    <div>
      <div class="bubble user">${escHtml(text)}</div>
      <div class="timestamp">${nowTime()}</div>
    </div>`;
      body.appendChild(el);
      msgCount++;
      scrollBottom();
    }

    function appendBotBubble(text) {
      const body = document.getElementById('chatBody');
      if (!body) return;
      const el = document.createElement('div');
      el.className = 'msg-row';
      el.innerHTML = `
    <div class="msg-avatar">🤖</div>
    <div>
      <div class="bubble bot">${mdToHtml(text)}</div>
      <div class="timestamp bot-ts">${nowTime()}</div>
    </div>`;
      body.appendChild(el);
      scrollBottom();
    }

    function showTypingIndicator() {
      const body = document.getElementById('chatBody');
      if (!body) return;
      const el = document.createElement('div');
      el.id = 'typingIndicator';
      el.className = 'msg-row';
      el.innerHTML = `
    <div class="msg-avatar">🤖</div>
    <div class="typing-indicator">
      <span class="dot"></span>
      <span class="dot"></span>
      <span class="dot"></span>
    </div>`;
      body.appendChild(el);
      scrollBottom();
    }

    function removeTypingIndicator() {
      const el = document.getElementById('typingIndicator');
      if (el) el.remove();
    }

    function hideSuggestionsPanel() {
      const area = document.getElementById('suggestionsArea');
      if (area) area.style.display = 'none';
    }

    // ── Welcome message ──────────────────────────────────────────
    function showWelcomeMessage() {
      const body = document.getElementById('chatBody');
      if (!body) return;
      const el = document.createElement('div');
      el.className = 'msg-row';
      el.innerHTML = `
    <div class="msg-avatar">🤖</div>
    <div>
      <div class="bubble bot">
        👋 Hello! Welcome to <strong>AI Solutions</strong>.<br><br>
