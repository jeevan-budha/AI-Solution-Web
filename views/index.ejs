    // ── Toggle / UI controls ─────────────────────────────────────
    function toggleChat() {
      const win = document.getElementById('chatWindow');
      const badge = document.getElementById('notifBadge');
      chatOpen = !chatOpen;

      if (chatOpen) {
        win.classList.add('open');
        if (badge) badge.style.display = 'none';
        if (msgCount === 0) showWelcomeMessage();
        chatMinimized = false;
        win.classList.remove('minimized');
        setTimeout(() => {
          const inp = document.getElementById('chatInput');
          if (inp) inp.focus();
        }, 340);
      } else {
        win.classList.remove('open');
      }
    }

    function toggleMinimize() {
      const win = document.getElementById('chatWindow');
      chatMinimized = !chatMinimized;
      win.classList.toggle('minimized', chatMinimized);
    }

    function clearChat() {
      const body = document.getElementById('chatBody');
      if (body) body.innerHTML = '';
      const area = document.getElementById('suggestionsArea');
      if (area) area.style.display = 'block';
      chatHistory = [];
      msgCount = 0;
      showWelcomeMessage();
    }

    // ── Input helpers ─────────────────────────────────────────────
    function handleKey(e) {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage();
      }
    }

    function autoResize(el) {
      el.style.height = 'auto';
      el.style.height = Math.min(el.scrollHeight, 90) + 'px';
    }

    function sendSuggestion(text) {
      const inp = document.getElementById('chatInput');
      if (!inp) return;
      inp.value = text;
      sendMessage();
    }

    // ── Secure API call through your own backend ──────────────────
    async function callGroq(userText) {
      const messages = [
        { role: 'system', content: SYSTEM_PROMPT },
        ...chatHistory,
        { role: 'user', content: userText }
      ];

      // Calls YOUR Express server — not Groq directly
      // API key stays safe on the server
      const response = await fetch('/api/chat', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ messages })
      });

      if (!response.ok) {
        let errMsg = `HTTP ${response.status}`;
        try {
          const errData = await response.json();
          errMsg = errData?.error || errMsg;
        } catch (_) { }
        throw new Error(errMsg);
      }

      const data = await response.json();
      const reply = data?.choices?.[0]?.message?.content?.trim();
      if (!reply) throw new Error('Empty response from server.');
      return reply;
    }

    // ── Main send ─────────────────────────────────────────────────
    async function sendMessage() {
      const inp = document.getElementById('chatInput');
      if (!inp) return;
      const text = inp.value.trim();
      if (!text) return;

      inp.value = '';
      inp.style.height = 'auto';

      appendUserBubble(text);
      hideSuggestionsPanel();
      showTypingIndicator();

      try {
        const reply = await callGroq(text);

        chatHistory.push({ role: 'user', content: text });
        chatHistory.push({ role: 'assistant', content: reply });

        if (chatHistory.length > 20) chatHistory = chatHistory.slice(-20);

        removeTypingIndicator();
        appendBotBubble(reply);

      } catch (err) {
        removeTypingIndicator();
        console.error('Chat error:', err);
        appendBotBubble(
          `❌ **Sorry, I couldn't get a response right now.**\n\nPlease try again in a moment, or contact us directly:\n📧 info@ai-solution.co.uk\n📞 +44 191 555 2026`
        );
      }
    }

    // ── Escape key closes chat ────────────────────────────────────
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && chatOpen) toggleChat();
    });
  </script>

  <script>
    // ═══════════════════════════════════════
    // AI GALAXY BACKGROUND ANIMATION
    // ═══════════════════════════════════════
    class AIGalaxy {
      constructor(canvas) {
        this.canvas = canvas;
        this.ctx = canvas.getContext('2d');
        this.resizeCanvas();
        this.stars = [];
        this.particles = [];
        this.dataPoints = [];
        this.initStars();
        this.initParticles();
        this.animate();
        window.addEventListener('resize', () => this.resizeCanvas());
      }

      resizeCanvas() {
        this.canvas.width = window.innerWidth;
        this.canvas.height = window.innerHeight;
      }

      initStars() {
        this.stars = [];
        for (let i = 0; i < 200; i++) {
          this.stars.push({
            x: Math.random() * this.canvas.width,
            y: Math.random() * this.canvas.height,
            radius: Math.random() * 1.5,
            opacity: Math.random() * 0.7 + 0.3,
            twinkleSpeed: Math.random() * 0.05,
            twinkleAmount: 0
          });
        }
      }

      initParticles() {
        this.particles = [];
        for (let i = 0; i < 50; i++) {
          this.particles.push({
            x: Math.random() * this.canvas.width,
            y: Math.random() * this.canvas.height,
            vx: (Math.random() - 0.5) * 0.5,
            vy: (Math.random() - 0.5) * 0.5,
            size: Math.random() * 2 + 1,
            color: ['#00d4ff', '#0066ff', '#7c3aed'][Math.floor(Math.random() * 3)],
            life: 1,
            maxLife: Math.random() * 3 + 2
          });
        }
      }

      drawStars() {
        this.stars.forEach(star => {
          star.twinkleAmount += star.twinkleSpeed;
          const opacity = star.opacity + Math.sin(star.twinkleAmount) * 0.3;

          this.ctx.fillStyle = `rgba(255, 255, 255, ${opacity})`;
          this.ctx.beginPath();
          this.ctx.arc(star.x, star.y, star.radius, 0, Math.PI * 2);
          this.ctx.fill();

          // Add glow
          this.ctx.fillStyle = `rgba(0, 212, 255, ${opacity * 0.3})`;
          this.ctx.beginPath();
          this.ctx.arc(star.x, star.y, star.radius * 3, 0, Math.PI * 2);
          this.ctx.fill();
        });
      }

      drawParticles() {
        this.particles.forEach((particle, index) => {
          particle.x += particle.vx;
          particle.y += particle.vy;
          particle.life -= 1 / (particle.maxLife * 60);

          if (particle.life <= 0) {
            this.particles.splice(index, 1);
            this.particles.push({
              x: Math.random() * this.canvas.width,
              y: Math.random() * this.canvas.height,
              vx: (Math.random() - 0.5) * 0.5,
              vy: (Math.random() - 0.5) * 0.5,
              size: Math.random() * 2 + 1,
              color: ['#00d4ff', '#0066ff', '#7c3aed'][Math.floor(Math.random() * 3)],
              life: 1,
              maxLife: Math.random() * 3 + 2
            });
          }

          this.ctx.fillStyle = particle.color.replace(')', `, ${particle.life})`).replace('rgb', 'rgba');
          this.ctx.beginPath();
          this.ctx.arc(particle.x, particle.y, particle.size, 0, Math.PI * 2);
          this.ctx.fill();

          // Draw trail
          this.ctx.strokeStyle = particle.color.replace(')', `, ${particle.life * 0.3})`).replace('rgb', 'rgba');
          this.ctx.lineWidth = 0.5;
          this.ctx.beginPath();
          this.ctx.moveTo(particle.x - particle.vx * 5, particle.y - particle.vy * 5);
          this.ctx.lineTo(particle.x, particle.y);
          this.ctx.stroke();
        });
      }

      drawConnections() {
        // Draw connections between nearby particles for AI neural effect
        for (let i = 0; i < this.particles.length; i++) {
          for (let j = i + 1; j < this.particles.length; j++) {
            const dx = this.particles[i].x - this.particles[j].x;
            const dy = this.particles[i].y - this.particles[j].y;
            const distance = Math.sqrt(dx * dx + dy * dy);

            if (distance < 150) {
              const opacity = (1 - distance / 150) * 0.3;
              this.ctx.strokeStyle = `rgba(0, 212, 255, ${opacity})`;
              this.ctx.lineWidth = 1;
              this.ctx.beginPath();
              this.ctx.moveTo(this.particles[i].x, this.particles[i].y);
              this.ctx.lineTo(this.particles[j].x, this.particles[j].y);
              this.ctx.stroke();
            }
          }
        }
      }

      animate() {
        this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);

        // Draw galaxy gradient background
        const gradient = this.ctx.createRadialGradient(
          this.canvas.width / 2, this.canvas.height / 2, 0,
          this.canvas.width / 2, this.canvas.height / 2, Math.max(this.canvas.width, this.canvas.height)
        );
        gradient.addColorStop(0, 'rgba(0, 102, 255, 0.1)');
        gradient.addColorStop(0.5, 'rgba(124, 58, 237, 0.05)');
        gradient.addColorStop(1, 'rgba(15, 15, 30, 0)');
        this.ctx.fillStyle = gradient;
        this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);

        this.drawStars();
        this.drawParticles();
        this.drawConnections();

        requestAnimationFrame(() => this.animate());
      }
    }

    // ═══════════════════════════════════════
    // NEURAL NETWORK ANIMATION
    // ═══════════════════════════════════════
    class NeuralNetwork {
      constructor(canvas) {
        this.canvas = canvas;
        this.ctx = canvas.getContext('2d');
        this.width = canvas.width;
        this.height = canvas.height;
        this.nodes = [];
        this.connections = [];
        this.initNetwork();
        this.animate();
      }

      initNetwork() {
        // Create neural network nodes
        const layers = [5, 8, 6, 4];
        let nodeIndex = 0;

        layers.forEach((nodeCount, layerIndex) => {
          const x = (layerIndex + 1) * (this.width / (layers.length + 1));
          for (let i = 0; i < nodeCount; i++) {
            const y = (i + 1) * (this.height / (nodeCount + 1));
            this.nodes.push({
              x: x,
              y: y,
              vx: (Math.random() - 0.5) * 2,
              vy: (Math.random() - 0.5) * 2,
              radius: Math.random() * 3 + 2,
              pulse: 0,
              pulseSpeed: Math.random() * 0.1 + 0.05,
              color: `hsl(${200 + Math.random() * 80}, 100%, 50%)`,
              energy: 0,
              layer: layerIndex
            });
          }
        });

        // Create connections between nearby nodes
        for (let i = 0; i < this.nodes.length; i++) {
          for (let j = i + 1; j < this.nodes.length; j++) {
            const dx = this.nodes[i].x - this.nodes[j].x;
            const dy = this.nodes[i].y - this.nodes[j].y;
            const distance = Math.sqrt(dx * dx + dy * dy);

            if (distance < 200 && Math.abs(this.nodes[i].layer - this.nodes[j].layer) <= 2) {
              this.connections.push({
                from: i,
                to: j,
                distance: distance,
                flow: Math.random(),
                flowSpeed: Math.random() * 0.03 + 0.01
              });
            }
          }
        }
      }

      draw() {
        this.ctx.clearRect(0, 0, this.width, this.height);

        // Draw connections with flow
        this.connections.forEach(conn => {
          const fromNode = this.nodes[conn.from];
          const toNode = this.nodes[conn.to];

          // Update flow
          conn.flow += conn.flowSpeed;
          if (conn.flow > 1) conn.flow = 0;

          // Draw connection line
          const gradient = this.ctx.createLinearGradient(
            fromNode.x, fromNode.y,
            toNode.x, toNode.y
          );
          gradient.addColorStop(0, `rgba(0, 212, 255, 0.1)`);
          gradient.addColorStop(conn.flow, `rgba(0, 102, 255, 0.8)`);
          gradient.addColorStop(1, `rgba(0, 212, 255, 0.1)`);

          this.ctx.strokeStyle = gradient;
          this.ctx.lineWidth = 1.5;
          this.ctx.beginPath();
          this.ctx.moveTo(fromNode.x, fromNode.y);
          this.ctx.lineTo(toNode.x, toNode.y);
          this.ctx.stroke();
        });

        // Draw nodes
        this.nodes.forEach(node => {
          node.pulse += node.pulseSpeed;
          const pulseAmount = Math.sin(node.pulse) * 3;

          // Node glow
          const glowGradient = this.ctx.createRadialGradient(node.x, node.y, 0, node.x, node.y, (node.radius + pulseAmount) * 3);
          glowGradient.addColorStop(0, `rgba(0, 212, 255, 0.4)`);
          glowGradient.addColorStop(1, `rgba(0, 212, 255, 0)`);
          this.ctx.fillStyle = glowGradient;
          this.ctx.beginPath();
          this.ctx.arc(node.x, node.y, (node.radius + pulseAmount) * 3, 0, Math.PI * 2);
          this.ctx.fill();

          // Node body
          const gradient = this.ctx.createRadialGradient(node.x, node.y, 0, node.x, node.y, node.radius + pulseAmount);
          gradient.addColorStop(0, `rgba(255, 255, 255, 0.9)`);
          gradient.addColorStop(1, node.color);
          this.ctx.fillStyle = gradient;
          this.ctx.beginPath();
          this.ctx.arc(node.x, node.y, node.radius + pulseAmount, 0, Math.PI * 2);
          this.ctx.fill();

          // Inner core
          this.ctx.fillStyle = `rgba(0, 212, 255, 0.8)`;
          this.ctx.beginPath();
          this.ctx.arc(node.x, node.y, Math.max(1, (node.radius + pulseAmount) * 0.4), 0, Math.PI * 2);
          this.ctx.fill();
        });
      }

      animate() {
        this.draw();
        requestAnimationFrame(() => this.animate());
      }
    }

    // Initialize animations
    window.addEventListener('load', () => {
      const galaxyCanvas = document.getElementById('aiGalaxy');
      const neuralCanvas = document.getElementById('neuralNetwork');

      if (galaxyCanvas) new AIGalaxy(galaxyCanvas);
